#!/usr/bin/env bash
# fusion-call — universal panelist dispatcher for the Fusion system.
#
#   fusion-call [--search] <panelist-name> "prompt"
#   fusion-call [--search] <panelist-name> < promptfile
#   fusion-call --provider <prov> --model <model> "prompt"   (ad-hoc, bypass roster)
#
# Reads ~/.claude/fusion/{providers.json,panel.json,secrets.env}.
# Prints the model's text answer to stdout. Errors prefixed "ERR:".
set -euo pipefail

FDIR="${CLAUDE_HOME:-$HOME/.claude}/fusion"
PROVIDERS="$FDIR/providers.json"
PANEL="$FDIR/panel.json"
SECRETS="$FDIR/secrets.env"

[ -f "$SECRETS" ] && { set -a; . "$SECRETS"; set +a; }

# --- --search flag (Tavily web search tool calling) ---
SEARCH_MODE=false
if [ "${1:-}" = "--search" ]; then
  SEARCH_MODE=true
  shift
fi

# --- Tavily config ---
TAVILY_KEY="${TAVILY_API_KEY:-}"
SEARCH_TURNS="${MAX_SEARCH_TURNS:-3}"

provider=""; model=""; name=""
if [ "${1:-}" = "--provider" ]; then
  provider="$2"; shift 2
  [ "${1:-}" = "--model" ] && { model="$2"; shift 2; }
else
  name="${1:?usage: fusion-call [--search] <panelist> [prompt]  |  fusion-call --provider <p> --model <m> [prompt]}"
  shift || true
  entry=$(jq -c --arg n "$name" '.panel[] | select(.name==$n)' "$PANEL" 2>/dev/null || true)
  [ -z "$entry" ] && { echo "ERR: unknown panelist '$name' (see panel.json)"; exit 1; }
  provider=$(jq -r '.provider' <<<"$entry")
  model=$(jq -r '.model' <<<"$entry")
fi

prompt="${*:-$(cat)}"
[ -z "$prompt" ] && { echo "ERR: empty prompt"; exit 1; }

# Materialize prompt + request body to temp files. Large-context prompts (up to ~1M
# tokens / multi-MB) exceed ARG_MAX, so they cannot be passed as argv to curl/jq/claude.
# printf is a shell builtin (no exec), so writing the prompt this way is ARG_MAX-safe.
promptfile=$(mktemp "${TMPDIR:-/tmp}/fusion-prompt.XXXXXX")
bodyfile=$(mktemp "${TMPDIR:-/tmp}/fusion-body.XXXXXX")
trap 'rm -f "$promptfile" "$bodyfile"' EXIT
printf '%s' "$prompt" > "$promptfile"

pdef=$(jq -c --arg p "$provider" '.providers[$p]' "$PROVIDERS" 2>/dev/null || true)
[ -z "$pdef" ] || [ "$pdef" = "null" ] && { echo "ERR: unknown provider '$provider'"; exit 1; }

ptype=$(jq -r '.type' <<<"$pdef")
endpoint=$(jq -r '.endpoint // ""' <<<"$pdef")
auth=$(jq -r '.auth // "bearer"' <<<"$pdef")
key_env=$(jq -r '.key_env // ""' <<<"$pdef")
# Output budget. Env CALL_MAX_TOKENS overrides (reasoning models on a big task can need
# a large budget or they spend it all on reasoning and return finish_reason=length).
maxtok="${CALL_MAX_TOKENS:-$(jq -r '.max_tokens // 8192' <<<"$pdef")}"
# Total request budget. Reasoning models on large prompts need minutes, not seconds.
# Override per provider with "request_timeout" in providers.json. Env CALL_TIMEOUT wins.
timeout="${CALL_TIMEOUT:-$(jq -r '.request_timeout // 600' <<<"$pdef")}"
key=""; [ -n "$key_env" ] && [ "$key_env" != "none" ] && key="${!key_env:-}"

# Keyless providers (e.g. self-hosted Ollama at localhost): key_env empty or "none" → no auth.
if [ "$ptype" != "claude-cli" ] && [ "$ptype" != "codex-responses" ] && [ -n "$key_env" ] && [ "$key_env" != "none" ] && [ -z "$key" ]; then
  echo "ERR: missing key \$$key_env for provider '$provider' (set it in secrets.env via /fusion-config)"; exit 1
fi

# Context-window guard (verified ceilings, 2026-06-16). Estimate input tokens from prompt
# bytes * provider tok_per_char and fail BEFORE a wasted multi-MB upload that the API would
# reject with an empty 200 (model_context_window_exceeded). Skip if provider omits the limits.
max_ctx=$(jq -r '.max_context_tokens // 0' <<<"$pdef")
tpc=$(jq -r '.tok_per_char // 0' <<<"$pdef")
if [ "$max_ctx" != "0" ] && [ "$tpc" != "0" ]; then
  pchars=$(wc -c < "$promptfile")
  est_in=$(awk -v c="$pchars" -v r="$tpc" 'BEGIN{printf "%d", c*r}')
  # input must fit alongside the reserved output (max_tokens) plus a small safety buffer
  allow_in=$(awk -v m="$max_ctx" -v o="$maxtok" 'BEGIN{printf "%d", m-o-512}')
  if [ "$est_in" -gt "$allow_in" ]; then
    max_chars=$(awk -v a="$allow_in" -v r="$tpc" 'BEGIN{printf "%d", a/r}')
    echo "ERR: prompt ~${est_in} tok exceeds ${model}'s usable window (~${allow_in} tok input, ceiling ${max_ctx}, reserving ${maxtok} for output). Shrink to <=~${max_chars} chars or split. Override the estimate only if you know it fits."
    exit 1
  fi
fi
# Reasoning models starve their answer if max_tokens is tiny (reasoning eats the budget,
# finish=length, empty answer). Floor it.
[ "$maxtok" -lt 512 ] && maxtok=512

# System prompt: per-panelist "system_prompt", else panel-wide "default_system_prompt",
# else env CALL_SYSTEM, else none (absent => unchanged behaviour for old installs).
sysprompt="${CALL_SYSTEM:-}"
if [ -z "$sysprompt" ] && [ -n "$name" ]; then
  sysprompt=$(jq -r --arg n "$name" '(.panel[]|select(.name==$n).system_prompt) // ""' "$PANEL" 2>/dev/null || echo "")
fi
[ -z "$sysprompt" ] && sysprompt=$(jq -r '.default_system_prompt // ""' "$PANEL" 2>/dev/null || echo "")

# Retry/fallback (#4): retry transient network failures with backoff. Per-provider "max_retries".
RETRIES=$(jq -r '.max_retries // 0' <<<"$pdef"); case "$RETRIES" in ''|*[!0-9]*) RETRIES=0;; esac
t0=$(date +%s)
RESP=""; RC=0

# curl exit code -> actionable message (#3 hardening)
curl_errmsg(){ case "$1" in
  6)  echo "DNS resolution failed (curl 6) — check the endpoint host for '$provider'";;
  7)  echo "connection refused (curl 7) — is the endpoint up? ($endpoint)";;
  28) echo "timeout after ${timeout}s (provider '$provider', model '$model'). Raise request_timeout or shrink the prompt.";;
  35|60|51) echo "SSL/TLS error (curl $1) talking to '$provider'";;
  *)  echo "curl failed (exit $1) for provider '$provider'";;
esac; }

# POST with retry. Sets globals RESP + RC (call directly, NOT in $() — must reach parent shell).
# Does not retry a full-budget timeout (28). Always returns 0 so set -e doesn't fire on RC.
http_post(){
  local tries=$((RETRIES+1)) a=0
  RC=0
  while [ "$a" -lt "$tries" ]; do
    RESP=$(curl -s --connect-timeout 15 -m "$timeout" "$endpoint" "$@") && { RC=0; return 0; } || RC=$?
    [ "$RC" -eq 28 ] && return 0
    a=$((a+1)); [ "$a" -lt "$tries" ] && sleep $((3*a))
  done
  return 0
}

# POST with streaming (for codex-responses which requires stream:true).
# Collects SSE output and extracts text from response.output_text.delta events.
http_post_sse(){
  local tries=$((RETRIES+1)) a=0
  RC=0
  while [ "$a" -lt "$tries" ]; do
    local raw
    raw=$(curl -s --no-buffer --connect-timeout 15 -m "$timeout" "$@" 2>&1) && { RC=0; } || RC=$?
    [ "$RC" -eq 28 ] && { RESP="$raw"; return 0; }
    if [ $RC -eq 0 ]; then
      # Check for HTTP errors in the response body
      if printf '%s' "$raw" | grep -q '"detail"' 2>/dev/null; then
        RESP="$raw"; return 0
      fi
      # Parse SSE: extract text from response.output_text.delta events + response.completed
      local extracted=""
      extracted=$(printf '%s\n' "$raw" | grep '^data: ' | while IFS= read -r line; do
        data="${line#data: }"
        [ "$data" = "[DONE]" ] && continue
        etype=$(printf '%s' "$data" | jq -r '.type // empty' 2>/dev/null) || continue
        if [ "$etype" = "response.output_text.delta" ]; then
          printf '%s' "$(printf '%s' "$data" | jq -r '.delta // empty' 2>/dev/null)"
        elif [ "$etype" = "response.completed" ]; then
          printf '%s' "$(printf '%s' "$data" | jq -r '[.response.output[].content[]? | select(.type=="output_text") | .text] | join("\n")' 2>/dev/null)"
        fi
      done 2>/dev/null)
      if [ -n "$extracted" ]; then
        # Wrap in a fake JSON for the finish() parser
        RESP=$(jq -n --arg t "$extracted" '{choices:[{message:{content:$t},finish_reason:"stop"}]}')
        return 0
      else
        RESP="$raw"; return 0
      fi
    fi
    a=$((a+1)); [ "$a" -lt "$tries" ] && sleep $((3*a))
  done
  return 0
}

# Append a JSONL telemetry line (#5) + a one-line status (#6). Best-effort, never fails the call.
log_call(){ # status
  local log="$FDIR/fusion.log" el=$(( $(date +%s) - t0 ))
  [ -f "$log" ] && [ "$(wc -c <"$log" 2>/dev/null || echo 0)" -gt 5000000 ] && mv "$log" "$log.1" 2>/dev/null
  printf '{"ts":"%s","panelist":"%s","provider":"%s","model":"%s","status":"%s","latency_s":%s,"bytes":%s}\n' \
    "$(date -u +%FT%TZ)" "${name:-adhoc}" "$provider" "$model" "$1" "$el" "${#RESP}" >> "$log" 2>/dev/null || true
  printf '%s\t%s/%s\t%s\t%ss\n' "${name:-adhoc}" "$provider" "$model" "$1" "$el" > "$FDIR/.last-call" 2>/dev/null || true
}

# Emit answer (or ERR), log status, exit. status derived from whether the answer is an ERR line.
finish(){ local ans="$1"; case "$ans" in ERR:*) log_call error;; *) log_call ok;; esac; printf '%s\n' "$ans"; exit 0; }

# Web search tool definition (OpenAI function calling format)
WEB_SEARCH_TOOL='[{"type":"function","function":{"name":"web_search","description":"Search the web for current, factual information, documentation, API references, pricing, or current events.","parameters":{"type":"object","properties":{"query":{"description":"The search query string","type":"string"}},"required":["query"]}}}]'

case "$ptype" in
  openai)
    if [ "$SEARCH_MODE" = "true" ] && [ -n "$TAVILY_KEY" ]; then
      # === MULTI-TURN WITH WEB SEARCH ===
      msgfile=$(mktemp "${TMPDIR:-/tmp}/fusion-msgs.XXXXXX")
      trap 'rm -f "$promptfile" "$bodyfile" "$msgfile" "${msgfile}.results" "${msgfile}.resp"' EXIT

      jq -n --arg m "$model" --arg s "$sysprompt" --rawfile p "$promptfile" --argjson mt "$maxtok" \
        '{model:$m, max_tokens:$mt,
          messages: ((if ($s|length)>0 then [{role:"system",content:$s}] else [] end)
                     + [{role:"user",content:$p}]),
          tools: '"$WEB_SEARCH_TOOL"'}' > "$msgfile"

      for turn in $(seq 1 $((SEARCH_TURNS + 1))); do
        http_post -H "Authorization: Bearer $key" -H "Content-Type: application/json" --data-binary @"$msgfile"
        [ "$RC" -ne 0 ] && { rm -f "$msgfile"; finish "ERR: $(curl_errmsg "$RC")"; }

        # Check for tool_calls
        has_tools=$(jq -r '.choices[0].message.tool_calls // [] | length' <<<"$RESP" 2>/dev/null)

        if [ "$has_tools" = "0" ] || [ -z "$has_tools" ]; then
          # No tool calls — final answer
          rm -f "$msgfile"
          ans=$(jq -r --argjson mt "$maxtok" 'def pick: .choices[0].message.content // .choices[0].message.reasoning_content // "";
            if (pick) != "" then pick
            elif (.choices[0].finish_reason // "") == "length" then "ERR: output truncated (finish_reason=length, max_tokens=\($mt)). Raise CALL_MAX_TOKENS."
            else "ERR: "+(.error.message // "no content") end' <<<"$RESP" 2>/dev/null) \
            || ans="ERR: unparseable response from '$provider'"
          finish "$ans"
        fi

        # Execute Tavily searches for each tool call
        echo '[]' > "${msgfile}.results"
        num_calls="$has_tools"
        for i in $(seq 0 $((num_calls - 1))); do
          call_id=$(jq -r ".choices[0].message.tool_calls[$i].id" <<<"$RESP")
          query=$(jq -r ".choices[0].message.tool_calls[$i].function.arguments | fromjson.query" <<<"$RESP" 2>/dev/null)
          query_escaped=$(jq -nR --arg q "$query" '$q')

          search_resp=$(curl -s --connect-timeout 10 -m 30 \
            -H "Authorization: Bearer $TAVILY_KEY" \
            -H "Content-Type: application/json" \
            -d "{\"query\":$query_escaped,\"max_results\":5,\"search_depth\":\"advanced\"}" \
            "https://api.tavily.com/search" 2>/dev/null) || search_resp='{"results":[]}'

          search_text=$(printf '%s' "$search_resp" | jq -r '[.results[]? | "• \(.title)\n  URL: \(.url)\n  \(.content[:400])"] | join("\n\n")' 2>/dev/null)
          [ -z "$search_text" ] && search_text="No results found."

          jq --arg cid "$call_id" --arg txt "$search_text" \
            '. + [{role:"tool", tool_call_id:$cid, content:$txt}]' "${msgfile}.results" > "${msgfile}.results.tmp"
          mv "${msgfile}.results.tmp" "${msgfile}.results"
        done

        # Rebuild request: original messages + assistant message (with tool_calls) + tool results
        # Write RESP to temp file (safe for large responses, avoids ARG_MAX)
        printf '%s' "$RESP" > "${msgfile}.resp"
        jq -n --slurpfile orig "$msgfile" --slurpfile results "${msgfile}.results" \
          --slurpfile resp "${msgfile}.resp" \
          --arg m "$model" --argjson mt "$maxtok" --argjson tools "$WEB_SEARCH_TOOL" \
          '($orig[0]) | .model=$m | .max_tokens=$mt | .tools=$tools |
           .messages += [$resp[0].choices[0].message] + $results[0]' > "${msgfile}.new" 2>/dev/null

        if [ -s "${msgfile}.new" ]; then
          mv "${msgfile}.new" "$msgfile"
        else
          rm -f "$msgfile"
          ans=$(jq -r '.choices[0].message.content // "[web search round failed]"' <<<"$RESP" 2>/dev/null)
          finish "$ans"
        fi
        log_call "search-turn-$turn"
      done

      rm -f "$msgfile"
      ans=$(jq -r '.choices[0].message.content // "[search rounds exhausted]"' <<<"$RESP" 2>/dev/null)
      finish "$ans"
    else
      # === STANDARD ONE-SHOT (no search) ===
      jq -n --arg m "$model" --arg s "$sysprompt" --rawfile p "$promptfile" --argjson mt "$maxtok" \
        '{model:$m,max_tokens:$mt,
          messages: ((if ($s|length)>0 then [{role:"system",content:$s}] else [] end)
                     + [{role:"user",content:$p}])}' > "$bodyfile"
      http_post -H "Authorization: Bearer $key" -H "Content-Type: application/json" --data-binary @"$bodyfile"
      [ "$RC" -ne 0 ] && finish "ERR: $(curl_errmsg "$RC")"
      ans=$(jq -r --argjson mt "$maxtok" 'def pick: .choices[0].message.content // .choices[0].message.reasoning_content // .choices[0].message.reasoning // "";
        if (pick) != "" then pick
        elif (.choices[0].finish_reason // "") == "length" then "ERR: output truncated (finish_reason=length, max_tokens=\($mt)). Raise the budget: CALL_MAX_TOKENS=<bigger> — a reasoning model likely spent it all on reasoning. (Not a context error; the input fit.)"
        elif (.choices[0].finish_reason // "") != "" then "ERR: empty output (finish_reason=\(.choices[0].finish_reason))."
        else "ERR: "+(.error.message // (.error|tostring) // "no content") end' <<<"$RESP" 2>/dev/null) || ans="ERR: unparseable response from '$provider' (not JSON): $(printf '%s' "$RESP" | head -c 160)"
      finish "$ans"
    fi
    ;;
  anthropic)
    jq -n --arg m "$model" --arg s "$sysprompt" --rawfile p "$promptfile" --argjson mt "$maxtok" \
      '{model:$m,max_tokens:$mt,messages:[{role:"user",content:$p}]}
       | (if ($s|length)>0 then .system=$s else . end)' > "$bodyfile"
    if [ "$auth" = "x-api-key" ]; then
      hdr=(-H "x-api-key: $key" -H "anthropic-version: 2023-06-01")
    else
      hdr=(-H "Authorization: Bearer $key" -H "anthropic-version: 2023-06-01")
    fi
    http_post "${hdr[@]}" -H "Content-Type: application/json" --data-binary @"$bodyfile"
    [ "$RC" -ne 0 ] && finish "ERR: $(curl_errmsg "$RC")"
    ans=$(jq -r --argjson mt "$maxtok" 'if (.content[0].text // "") != "" then .content[0].text
           elif (.stop_reason // "") == "max_tokens" then "ERR: output truncated (stop_reason=max_tokens, max_tokens=\($mt)). Raise the budget: CALL_MAX_TOKENS=<bigger>. (Not a context error; the input fit.)"
           elif (.stop_reason // "") != "" then "ERR: empty output (stop_reason=\(.stop_reason)). Likely context window exceeded — shrink the prompt."
           else "ERR: "+(.error.message // (.error|tostring) // "no content") end' <<<"$RESP" 2>/dev/null) || ans="ERR: unparseable response from '$provider' (not JSON): $(printf '%s' "$RESP" | head -c 160)"
    finish "$ans"
    ;;
  codex-responses)
    # Resolve tokens: prefer ~/.codex/auth.json, fall back to secrets.env
    codex_auth="$HOME/.codex/auth.json"
    if [ -f "$codex_auth" ]; then
      # codex CLI nests tokens under .tokens.*; older layouts had them top-level. Try both.
      key=$(jq -r '(.tokens.access_token // .access_token) // empty' "$codex_auth" 2>/dev/null) || true
      if [ -z "${CODEX_ACCOUNT_ID:-}" ]; then
        CODEX_ACCOUNT_ID=$(jq -r '(.tokens.account_id // .account_id) // empty' "$codex_auth" 2>/dev/null) || true
      fi
    fi

    # Auto-refresh: if the access token is expired / within 120s of expiry and we have a
    # refresh_token + the login helper, refresh silently before calling (avoids a 401).
    if [ -n "$key" ] && [ -f "$codex_auth" ] && [ -x "$FDIR/ccf-codex-login" ] && command -v python3 >/dev/null 2>&1; then
      exp=$(printf '%s' "$key" | cut -d. -f2 | tr '_-' '/+' | base64 -d 2>/dev/null | jq -r '.exp // 0' 2>/dev/null) || exp=0
      if [ "${exp:-0}" -gt 0 ] && [ "$(date +%s)" -ge $((exp - 120)) ] \
         && jq -e '(.tokens.refresh_token // "")|length>0' "$codex_auth" >/dev/null 2>&1; then
        python3 "$FDIR/ccf-codex-login" --refresh >/dev/null 2>&1 || true
        key=$(jq -r '(.tokens.access_token // .access_token) // empty' "$codex_auth" 2>/dev/null) || true
        CODEX_ACCOUNT_ID=$(jq -r '(.tokens.account_id // .account_id) // empty' "$codex_auth" 2>/dev/null) || true
      fi
    fi

    # Extract account ID from JWT if still not set
    if [ -z "${CODEX_ACCOUNT_ID:-}" ] && [ -n "$key" ]; then
      payload_b64=$(printf '%s' "$key" | cut -d. -f2)
      CODEX_ACCOUNT_ID=$(printf '%s' "$payload_b64" | tr '_-' '/+' | base64 -d 2>/dev/null \
        | jq -r '.["https://api.openai.com/auth"].chatgpt_account_id // empty' 2>/dev/null) || true
    fi

    [ -z "$key" ] && finish "ERR: no Codex token. Log in via browser:  ~/.claude/fusion/ccf-codex-login   (no codex CLI needed)"
    [ -z "${CODEX_ACCOUNT_ID:-}" ] && finish "ERR: could not extract ChatGPT-Account-ID from token. Set CODEX_ACCOUNT_ID manually."

    codex_endpoint="${endpoint%/}/responses"

    # Codex Responses API requires: instructions (system prompt), store=false, stream=true
    # Does NOT support max_output_tokens.
    sys_default="${sysprompt}"
    [ -z "$sys_default" ] && sys_default="You are a panelist in a multi-model fusion system. Answer the task concisely and accurately."

    jq -n --arg m "$model" --arg s "$sys_default" --rawfile p "$promptfile" \
      '{model:$m, instructions:$s,
        input: [{role:"user", content:[{type:"input_text", text:$p}]}],
        store:false, stream:true}' > "$bodyfile"

    # POST with SSE streaming support
    http_post_sse "$codex_endpoint" \
      -H "Authorization: Bearer $key" \
      -H "Content-Type: application/json" \
      -H "User-Agent: codex_cli_rs/0.0.0" \
      -H "originator: codex_cli_rs" \
      -H "ChatGPT-Account-ID: $CODEX_ACCOUNT_ID" \
      --data-binary @"$bodyfile"

    [ "$RC" -ne 0 ] && finish "ERR: $(curl_errmsg "$RC")"

    # Check for Codex-specific errors
    if printf '%s' "$RESP" | grep -qi '"usage_limit_reached"\|429'; then
      finish "ERR: Codex usage limit reached (quota exhausted). Resets later. Check your OpenAI plan."
    fi
    if printf '%s' "$RESP" | grep -qi 'cf-mitigated\|cloudflare'; then
      finish "ERR: Cloudflare blocked Codex request (403). Headers may be wrong or IP flagged."
    fi
    if printf '%s' "$RESP" | grep -qi '"detail".*Instructions are required"'; then
      finish "ERR: Codex API requires 'instructions' field. Internal error — please report."
    fi
    if printf '%s' "$RESP" | grep -qi '"detail".*token.*expired\|"status":401\|invalid_api_key'; then
      finish "ERR: Codex token expired. Refresh:  ~/.claude/fusion/ccf-codex-login --refresh   (or re-login: ccf-codex-login)"
    fi

    # Parse: http_post_sse already extracts text into fake choices JSON if successful
    ans=$(jq -r '.choices[0].message.content // empty' <<<"$RESP" 2>/dev/null) || true
    if [ -z "$ans" ] || [ "$ans" = "null" ]; then
      # SSE extraction failed — try raw parse
      ans=$(printf '%s' "$RESP" | grep '^data: ' | grep 'response.output_text.delta' \
        | jq -r '.delta // empty' 2>/dev/null | tr -d '\n') || true
    fi
    if [ -z "$ans" ]; then
      ans="ERR: empty/unparseable Codex response. First 200 chars: $(printf '%s' "$RESP" | head -c 200)"
    fi
    finish "$ans"
    ;;
  claude-cli)
    ans=$(claude -p --model "$model" < "$promptfile" 2>&1) || ans="ERR: claude CLI failed — $(printf '%s' "$ans" | head -c 160)"
    RESP="$ans"; finish "$ans"
    ;;
  *)
    echo "ERR: unsupported provider type '$ptype'"; exit 1
    ;;
esac

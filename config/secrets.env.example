# CCF secrets — copy this file to secrets.env and fill in only the keys you use.
#
#   cp secrets.env.example secrets.env
#   chmod 600 secrets.env
#
# NEVER commit secrets.env (it is gitignored). Each value is the API key/token for
# a provider declared in providers.json via its "key_env" field.

# z.ai — GLM-5.2, 1M context, zero-retention. https://z.ai/manage-apikey/apikey-list
ZAI_API_KEY=

# OpenCode Go — flat-rate subscription (DeepSeek-V4-Pro 1M, etc), zero-retention. https://opencode.ai
OPENCODE_GO_KEY=

# OpenCode Zen — pay-per-token. NOT zero-retention; do not send proprietary code. https://opencode.ai
OPENCODE_ZEN_KEY=

# Optional — only if you add these providers via /fusion-config:
# GEMINI_API_KEY=
# MOONSHOT_API_KEY=
# OPENROUTER_API_KEY=
